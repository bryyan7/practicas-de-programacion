import java.util.ArrayList;

public class MiRed{
    private ArrayList<Perfil> perfiles;
    private int contadorId;
    
    public MiRed(){
        perfiles= new ArrayList<Perfil>();
        contadorId=1;
    }
    public void anadirPerfil (Perfil perfilNuevo){
        perfiles.add(perfilNuevo);
        String idNuevo = "user"+ contadorId;
        perfilNuevo.setIdUsuario(idNuevo);
        perfilNuevo.setURL("http://www.MiRed.com/" + idNuevo);
        contadorId++;
    }
    public Perfil buscarUsuario(String idBuscado){
        int i=0;
        while(i<perfiles.size()){
            if (perfiles.get(i).getIdUsuario().equals(idBuscado)){
                return perfiles.get(i);
            }
            i++;
        }
        return null;
    }
    public boolean comprobarPassword(String idUsuario, String passwordBuscada){
        Perfil perfilBuscado=buscarUsuario(idUsuario);
        if (perfilBuscado==null){
            System.out.println("No existe el usuario " + idUsuario);
            return false;
        }
        else if (perfilBuscado.getPassword().equals(passwordBuscada)){
            System.out.println("Contraseña correcta");
            return true;
        }
        else {
            System.out.println("Contraseña incorrecta");
            return false;
        }
    }
    public void visualizarRed(){
        System.out.println("Usuarios en la red:");
        for(int i=0;i<perfiles.size();i++){
            System.out.println("    "+perfiles.get(i).getIdUsuario()+": "+perfiles.get(i).getNombre());
        }
    }
    public void visualizarPerfil(String idUsuario){
        Perfil perfilBuscado=buscarUsuario(idUsuario);
        if ( perfilBuscado == null){
            System.out.println("No existe el usuario " + idUsuario);
        }
        else{
            perfilBuscado.imprimeInformacion();
        }
    }
    public void anadirPost(String idUsuario, String texto){
        Perfil perfilBuscado=buscarUsuario(idUsuario);
        if (perfilBuscado==null){
            System.out.println("No existe el identificador de usuario " + idUsuario);
        }
        else{
            Post postNuevo= new Post();
            postNuevo.setTexto(texto);
            
            int numeroPost=perfilBuscado.getPosts().size()+1;
            postNuevo.setURL("http://www.miRed.com/post/" + idUsuario + "."+ numeroPost);
            
            perfilBuscado.anadirPost(postNuevo);
        }
    }
    public void eliminarPerfil (String idUsuario){
        Perfil perfilBuscado = buscarUsuario(idUsuario);
        if (perfilBuscado == null) {
            System.out.println("No existe el usuario" + idUsuario);
        }
        else{
            perfiles.remove(perfilBuscado);
        }
    }
    public void eliminaarPost (String idUsuario, String URLBuscada){
        Perfil perfilBuscado = buscarUsuario(idUsuario);
        if (perfilBuscado == null){
            System.out.println("No existe el usuario " + idUsuario);
            }
        ArrayList<Post> posts = perfilBuscado.getPosts();
        for ( int i = 0; i < posts.size(); i++){
            if (posts.get(i).getURL().equals(URLBuscada)){
                posts.remove(i);
            }
            else {
            System.out.println("No existe el post " + URLBuscada);
            }
        }
    }
    public void eliminarPost (String idUsuario, String URLBuscada){
        for (Perfil perfilBuscado: perfiles){
            ArrayList<Post> posts = perfilBuscado.getPosts();
            for (int i = 0; i<posts.size(); i++){
                if (posts.get(i).getURL().equals(URLBuscada)){
                    posts.remove(i);
                }
                else {
                    System.out.println("No se ha encontrado el post " + URLBuscada);
                }
            }
        }
    }
}
