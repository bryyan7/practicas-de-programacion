import java.util.ArrayList;

public class Perfil{
    private String nombre;
    private String password;
    private String idUsuario;
    private String URL;
    private Biografia biografia;
    private ArrayList<Post> posts;
    
    //constructor
    public Perfil(String nombre, String password){
        this.nombre=nombre;
        this.password=password;
        this.idUsuario="";
        this.URL="";
        this.biografia=null;
        this.posts=new ArrayList<Post>();
    }
    //setters
    public void setNombre(String nombreNuevo){
        nombre=nombreNuevo;
    }
    public void setPassword(String passwordNueva){
        password=passwordNueva;
    }
    public void setIdUsuario(String idNuevo){
        idUsuario= idNuevo;
    }
    public void setURL(String URLNueva){
        URL= URLNueva;
    }
    public void setBiografia(Biografia biografiaNueva){
        biografia= biografiaNueva;
    }
    public void anadirPost(Post postNuevo){
        posts.add(postNuevo);
    }
    //getters
    public String getNombre(){
        return nombre;
    }
    public String getPassword(){
        return password;
    }
    public String getIdUsuario(){
        return idUsuario;
    }
    public String getURL(){
        return URL;
    }
    public Biografia getBiografia(){
        return biografia;
    }
    public ArrayList<Post> getPosts(){
        return posts;
    }
    //imprimir info
    public void imprimeInformacion(){
        System.out.println("Identificador de usuario: " + idUsuario);
        System.out.println("    Nombre: " + nombre);
        System.out.println("    Password: " + password);
        System.out.println("    URL: " + URL);
        System.out.println("    BIO: ");
        biografia.imprimeInformacion();
        if (posts==null||posts.isEmpty()){
             //no imprime nada
        }
        else{
            System.out.println(" POSTS:");
        }
        for(int i=0; i<posts.size();i++){
            posts.get(i).imprimeInformacion();
        }
    }
}
