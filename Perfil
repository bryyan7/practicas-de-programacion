package practicas;
import java.util.ArrayList;

public class Perfil {
	private String nombre;
	private String idUsuario;
	private String password;
	private String URL;
	private Biografia biografia;
	private ArrayList<Post> posts;
	
	//constructor
	public Perfil(String nombre, String password) {
		this.nombre="";
		this.idUsuario="";
		this.password="";
		this.URL="";
	}
	
	//setters
	public void setNombre(String nombre) {
		this.nombre = nombre;
	}
	public void setPassword(String password) {
		this.password = password;
	}
	public void setIdUsuario(String idUsuario) {
		this.idUsuario = idUsuario;
	}
	public void setURL(String uRL) {
		URL = uRL;
	}
	public void setBiografia(Biografia biografiaNueva) {
		biografia=biografiaNueva;
	}
	public void setPosts(ArrayList<Post> posts) {
		this.posts = posts;
	}

	//getters
	public String getNombre() {
		return nombre;
	}
	public String getPassword() {
		return password;
	}
	public String getIdUsuario() {
		return idUsuario;
	}
	public String getURL() {
		return URL;
	}
	public Biografia getBiografia() {
		return biografia;
	}
	public ArrayList<Post> getPosts() {
		return posts;
	}

	//print information
	public void imprimeInformacion() {
		System.out.println("Identificador de usuario: " + idUsuario);
		System.out.println("	Nombre: " + nombre);
		System.out.println("    URL: " + URL);
		System.out.println("    BIO: ");
		biografia.imprimeInformacion();
	}

	public void anadirPost(Post postNuevo) {
		posts.add(postNuevo);
	}
	
}
